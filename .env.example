# ============================================================
# ACEPTA BITCOIN MÉXICO — Environment Configuration
# Oracle System v2.0 — Caja Registradora + B.O.B.
# Última actualización: Mayo 2026
# ============================================================

# ── ⚡ BLINK.SV — CAJA REGISTRADORA (Obligatorio) ──
# Credenciales desde: https://dashboard.blink.sv/settings/api-keys
BLINK_API_KEY=your_blink_api_key_here
BLINK_API_URL=https://api.blink.sv/graphql
BLINK_WALLET_ID=your_wallet_id_here

# Lightning Address pública (usada en frontend y backend)
NEXT_PUBLIC_LIGHTNING_ADDRESS=aceptabitcoin@blink.sv

# Opcionales para Blink (recomendado mantener consistencia)
NEXT_PUBLIC_BLINK_HANDLE=aceptabitcoin
NEXT_PUBLIC_BLINK_DOWNLOAD=https://blink.sv/download

# ── 🤖 B.O.B. Chat / AI (Groq + Upstash) ──
GROQ_API_KEY=your_groq_api_key_here

UPSTASH_VECTOR_REST_URL=https://your-vector-db.upstash.io
UPSTASH_VECTOR_REST_TOKEN=your_upstash_vector_token_here

# ── 📊 Market Data (Binance) ──
# Usado por MarketMoodWidget y Blink (precio USD → sats)
NEXT_PUBLIC_BINANCE_API_BASE=https://api.binance.com/api/v3

# ── 🗺️ Otras Integraciones ──
BTCMAP_API_KEY=your_btcmap_api_key_here                  # Si reactivamos mapa
NEXT_PUBLIC_CAL_COM_URL=https://cal.com/tu-usuario       # Agenda

# ── Hackathon Module ──
NEXT_PUBLIC_HACKATHON_REGISTRATION_FORM_URL=https://luma.com/kzdw3pek
NEXT_PUBLIC_HACKATHON_REGISTRATION_URL=https://luma.com/kzdw3pek

# ── 🌐 Configuración General del Sitio ──
NEXT_PUBLIC_APP_URL=https://aceptabitcoin.org
NEXT_PUBLIC_SITE_NAME="Acepta Bitcoin México"

# ── 🛡️ Monitoreo y Emails ──
SENTRY_DSN=your_sentry_dsn_here
NEXT_PUBLIC_SENTRY_DSN=your_sentry_public_dsn_here

RESEND_API_KEY=re_your_resend_api_key_here

# ── Seguridad y Optimizaciones ──
NEXT_TELEMETRY_DISABLED=1

# ============================================================
# NOTAS IMPORTANTES:
# 1. Copia este archivo a .env.local y llena los valores reales
# 2. NUNCA subas .env.local a Git
# 3. Después de cambiar variables, reinicia el servidor (npm run dev)
# 4. Blink requiere BLINK_API_KEY + BLINK_WALLET_ID para crear invoices
# ============================================================
