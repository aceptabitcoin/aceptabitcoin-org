# ============================================================
# ACEPTA BITCOIN MÉXICO — Environment Configuration
# Oracle System v2.0
# ============================================================

# ── Blink API Configuration ──
# Get your API key from: https://dashboard.blink.sv/settings/api-keys
BLINK_API_KEY=your_blink_api_key_here

# Your Blink Lightning Address (e.g., yourhandle@blink.sv)
NEXT_PUBLIC_BLINK_LIGHTNING_ADDRESS=yourhandle@blink.sv
NEXT_PUBLIC_BLINK_HANDLE=yourhandle

# ── Optional: LNbits (legacy, kept for reference) ──
# LNbits_URL=https://your-lnbits-instance.com
# LNbits_API_KEY=your_lnbits_api_key

# ── Next.js ──
NEXT_PUBLIC_APP_URL=https://aceptabitcoin.org

# ── Sentry (Error Monitoring) ──
# Get your DSN from: https://sentry.io/settings/projects/<your-project>/keys/
# Leave empty to disable Sentry
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=

# ── Hackathon ──
# Google Form URL for team registration
NEXT_PUBLIC_HACKATHON_REGISTRATION_FORM_URL=https://forms.gle/TU_FORMULARIO_AQUI
