# ============================================================
# ACEPTA BITCOIN MÉXICO — Environment Configuration
# Oracle System v2.0 + B.O.B. Chat Module
# ============================================================

# ── 🤖 B.O.B. Chat / RAG Configuration (NEW) ──
# Groq API Key for Llama 3.3 inference (https://console.groq.com/keys)
GROQ_API_KEY=your_groq_api_key_here

# Upstash Vector for RAG (https://upstash.com/docs/vector)
UPSTASH_VECTOR_REST_URL=https://your-vector-db.upstash.io
UPSTASH_VECTOR_REST_TOKEN=your_upstash_vector_token_here

# ── ⚡ Blink.sv API — TipJar & Payments ──
# Get credentials from: https://dashboard.blink.sv/settings/api-keys
BLINK_API_KEY=your_blink_api_key_here
BLINK_API_URL=https://api.blink.sv/graphql
BLINK_WALLET_ID=your_wallet_id_here

# Public Lightning Address for donations (displayed in UI)
NEXT_PUBLIC_BLINK_LIGHTNING_ADDRESS=yourhandle@blink.sv
NEXT_PUBLIC_BLINK_HANDLE=yourhandle
NEXT_PUBLIC_LIGHTNING_ADDRESS=yourhandle@blink.sv
NEXT_PUBLIC_BLINK_DOWNLOAD=https://blink.sv/download

# ── 🗺️ BTC Map API ──
# Merchant map data (https://btcmap.org/api)
BTCMAP_API_KEY=your_btcmap_api_key_here

# ── 📊 Market Data (Binance) ──
# Used by MarketMoodWidget for DCA indicator
# No API key required for public endpoints, but rate limits apply
NEXT_PUBLIC_BINANCE_API_BASE=https://api.binance.com/api/v3

# ── 📅 Cal.com Booking ──
# Embedded calendar for /agenda route
NEXT_PUBLIC_CAL_COM_URL=https://cal.com/your-username

# ── 🎮 Hackathon Module ──
# Google Form for team registration (replace with your form)
NEXT_PUBLIC_HACKATHON_REGISTRATION_FORM_URL=https://forms.gle/TU_FORMULARIO_AQUI

# ── 🌐 Next.js Core ──
NEXT_PUBLIC_APP_URL=https://aceptabitcoin.org
NEXT_PUBLIC_SITE_NAME="Acepta Bitcoin México"

# ── 🐛 Sentry Error Monitoring ──
# Get DSN from: https://sentry.io/settings/projects/<project>/keys/
# Leave empty to disable in dev
SENTRY_DSN=your_sentry_dsn_here
NEXT_PUBLIC_SENTRY_DSN=your_sentry_public_dsn_here

# ── 📧 Resend (Transactional Email) ──
# For hackathon registration confirmations, etc.
RESEND_API_KEY=re_your_resend_api_key

# ── 🔐 Security / Optional ──
# Disable telemetry in production if desired
NEXT_TELEMETRY_DISABLED=1

# ── 🧪 Legacy / Reference (Do not use unless migrating) ──
# LNbits_URL=https://your-lnbits-instance.com
# LNbits_API_KEY=your_lnbits_api_key
# ⚠️ LNbits is deprecated; use Blink.sv for new integrations